{
  "rules": {
    "senha_atual": {
      ".read": true,
      ".write": true,
      ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 999"
    },
    "ultima_senha_gerada": {
      ".read": true,
      ".write": true,
      ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 999"
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
